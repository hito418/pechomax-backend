rules_version = '2';

// Backend uploads via firebase-admin (bypasses these rules).
// Clients receive tokenized download URLs, so anonymous read is acceptable.
service firebase.storage {
  match /b/{bucket}/o {
    match /profilePic/{file=**} {
      allow read: if true;
      allow write: if false;
    }
    match /message/{file=**} {
      allow read: if true;
      allow write: if false;
    }
    match /catch/{file=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
